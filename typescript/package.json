{
  "name": "polaris-news-api",
  "version": "0.9.1",
  "description": "DEPRECATED — use @veroq/sdk instead. TypeScript SDK for The Polaris Report Knowledge API.",
  "deprecated": "This package has been renamed to @veroq/sdk. Please install @veroq/sdk instead.",
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/esm/index.d.ts",
        "default": "./dist/esm/index.js"
      },
      "require": {
        "types": "./dist/cjs/index.d.ts",
        "default": "./dist/cjs/index.js"
      }
    }
  },
  "bin": {
    "polaris": "./dist/esm/cli.js"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "build:esm": "tsc -p tsconfig.esm.json",
    "build:cjs": "tsc -p tsconfig.cjs.json",
    "build": "npm run build:esm && npm run build:cjs",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "polaris",
    "news",
    "api",
    "sdk",
    "knowledge",
    "ai",
    "agents",
    "intelligence",
    "typescript",
    "nlp"
  ],
  "author": {
    "name": "The Polaris Report",
    "email": "dev@thepolarisreport.com",
    "url": "https://thepolarisreport.com"
  },
  "license": "MIT",
  "homepage": "https://thepolarisreport.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/polaris-news/polaris-sdks",
    "directory": "typescript"
  },
  "bugs": {
    "url": "https://github.com/polaris-news/polaris-sdks/issues"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.4.0",
    "vitest": "^3.0.0"
  }
}
